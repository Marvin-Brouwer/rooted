{
	"extends": "./.repo/config/ts/base.json",
	"compilerOptions": {
		"noEmit": true,
		"lib": ["DOM", "ES2024"]
	},
	"include": [
		"**/*.ts",
		"**/*.mts",
		"**/*.cts",
		"**/*.tsx",
		"**/*.js",
		"**/*.mjs",
		"**/*.cjs",
		".repo/**/*.ts",
		".repo/**/*.mts"
	],
	"exclude": [
		"node_modules",
		"**/node_modules",
		"**/dist",
		"docs",
		"temp",
		"packages/*/tests"
	]
}
