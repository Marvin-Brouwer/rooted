{
	"rules": {
		"local/mjs-to-mts": "error",
		"local/utf-encoding": "error",
		"unicorn-js/prevent-abbreviations": ["error", {
			"allowList": {
				"dev": true,
				"dev.mts": true,
				"util": true,
				"util.mts": true,
				"dotEnv": true,
				"devHelper": true,
				"dev-helper": true,
				"vite-env": true,
				"vite-env.d": true,
				"env.d": true,
				"env.d.ts": true
			}
		}]
	}
}
