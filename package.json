{
	"name": "@rooted/monorepo",
	"private": true,
	"description": "rooted — web components rooted very close to the original",
	"scripts": {
		"prepare": "husky",
		"dev": "rooted-development development-runner examples/recipe-book",
		"build": "pnpm -r --stream run build",
		"build:dev": "pnpm -r --stream run build:dev",
		"build:ci": "pnpm -r run build:ci",
		"test": "vp test",
		"test:watch": "vp test --watch",
		"lint:nofix": "oxlint -c .oxlintrc.json . && node .repo/config/check-packages.mjs",
		"lint": "oxlint -c .oxlintrc.json --fix . && node .repo/config/check-packages.mjs",
		"clean": "pnpm -r run clean",
		"release": "multi-semantic-release --ignore-private-packages",
		"full-update": "pnpm update -r"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@rooted/development": "workspace:*",
		"@rooted/pipeline": "workspace:*",
		"@types/unist": "^3.0.3",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"multi-semantic-release": "^3.1.0",
		"oxlint": "^1.64.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vite-plus": "^0.1.21",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"packageManager": "pnpm@11.0.9",
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"vite-plugin-pwa>vite": "8"
			}
		},
		"overrides": {
			"source-map@0.8.0-beta.0": "0.7.4",
			"sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15"
		},
		"allowedDeprecatedVersions": {
			"glob": "11"
		},
		"patchedDependencies": {
			"semantic-release@25.0.3": "patches/semantic-release@25.0.3.patch"
		}
	}
}
