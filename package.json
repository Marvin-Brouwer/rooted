{
	"name": "@rooted/monorepo",
	"private": true,
	"description": "rooted — web components rooted very close to the original",
	"scripts": {
		"prepare": "husky",
		"dev": "rooted-development development-runner examples/recipe-book",
		"build": "pnpm -r --stream run build",
		"build:dev": "pnpm -r --stream run build:dev",
		"build:ci": "pnpm -r run build:ci",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint:nofix": "eslint --cache --stats -c \"./eslint.config.ts\" .",
		"lint": "DEBUG=eslint:cli-engine eslint --cache --fix --stats --debug -c \"./eslint.config.ts\" .",
		"clean": "pnpm -r run clean",
		"release": "multi-semantic-release"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
