{
	"name": "@rooted/monorepo",
	"private": true,
	"description": "rooted — web components rooted very close to the original",
	"scripts": {
		"prepare": "husky",
		"dev": "rooted-development development-runner examples/recipe-book",
		"build": "pnpm -r --stream run build",
		"build:dev": "pnpm -r --stream run build:dev",
		"build:ci": "pnpm -r run build:ci",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint:nofix": "eslint --cache --stats -c \"./.repo/config/eslint/eslint.config.ts\" .",
		"lint": "DEBUG=eslint:cli-engine eslint --cache --fix --stats --debug -c \"./.repo/config/eslint/eslint.config.ts\" .",
		"clean": "pnpm -r run clean",
		"release": "multi-semantic-release --ignore-private-packages"
	},
	"release": {
		"extends": "./.repo/config/conventions/.releaserc.json"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@rooted/development": "workspace:*",
		"@rooted/pipeline": "workspace:*",
		"@stylistic/eslint-plugin": "^5.5.0",
		"@types/micromatch": "^4.0.10",
		"@types/unist": "^3.0.3",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"eslint": "^10.2.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-package-json": "^0.91.1",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-unused-imports": "^4.3.0",
		"globals": "^17.5.0",
		"happy-dom": "^20.9.0",
		"husky": "^9.0.0",
		"multi-semantic-release": "^3.0.2",
		"tsup": "^8.0.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"vite-plugin-pwa>vite": "8",
				"eslint-plugin-import>eslint": "10"
			}
		},
		"overrides": {
			"source-map@0.8.0-beta.0": "0.7.4",
			"sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15"
		},
		"allowedDeprecatedVersions": {
			"glob": "11"
		},
		"patchedDependencies": {
			"semantic-release@25.0.3": "patches/semantic-release@25.0.3.patch"
		}
	}
}
