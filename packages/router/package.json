{
	"name": "@rooted/router",
	"version": "0.1.0",
	"description": "rooted — client-side router with typed URL parameters and Vite integration",
	"keywords": [
		"router",
		"client-side-routing",
		"web-components",
		"typescript",
		"vite",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/router"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/router.mjs",
			"types": "./dist/router.d.mts"
		},
		"./manifest": {
			"import": "./dist/manifest.mjs",
			"types": "./dist/manifest.d.mts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@rooted/util": "workspace:*",
		"@rooted/components": "workspace:*",
		"tinyglobby": "^0.2.0"
	},
	"peerDependencies": {
		"vite": ">=6.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"vite": "^6.0.0"
	}
}
