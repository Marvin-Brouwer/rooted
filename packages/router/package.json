{
	"name": "@rooted/router",
	"version": "1.0.0-alpha.0",
	"description": "rooted — client-side router with typed URL parameters and Vite integration",
	"keywords": [
		"router",
		"client-side-routing",
		"web-components",
		"typescript",
		"vite",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/router"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"bugs": "https://github.com/Marvin-Brouwer/rooted/issues",
	"sideEffects": false,
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"source": "./src/_module/router.mts",
			"import": "./dist/router.mjs",
			"types": "./dist/router.d.mts"
		},
		"./application": {
			"source": "./src/_module/application.mts",
			"import": "./dist/application.mjs",
			"types": "./dist/application.d.mts"
		},
		"./routes": {
			"source": "./src/_module/routes.mts",
			"import": "./dist/routes.mjs",
			"types": "./dist/routes.d.mts"
		},
		"./manifest": {
			"source": "./plugins/_module/manifest.mts",
			"import": "./dist/manifest.mjs",
			"types": "./dist/manifest.d.mts"
		}
	},
	"scripts": {
		"build": "pnpm build:ci",
		"build:dev": "pnpm build:ci && rooted-development extract-api",
		"build:ci": "tsup",
		"watch": "tsup --watch --no-clean & rooted-development extract-api",
		"clean": "rm -rf dist",
		"extract-api": "rooted-development extract-api"
	},
	"dependencies": {
		"jiti": "^2.0.0",
		"tinyglobby": "^0.2.0"
	},
	"peerDependencies": {
		"@rooted/util": "workspace:^",
		"@rooted/components": "workspace:^",
		"vite": ">=8.0.1"
	},
	"devDependencies": {
		"@rooted/util": "workspace:^",
		"@rooted/components": "workspace:^",
		"@rooted/development": "workspace:*",
		"@rooted/tsup": "workspace:^",
		"@types/node": "^25.6.0",
		"tsx": "^4.19.0",
		"vite": "^8.0.5"
	}
}
