{
	"name": "@rooted/application",
	"version": "1.0.0-alpha.0",
	"description": "Build-time configuration and SEO tooling for the rooted framework",
	"keywords": [
		"web-components",
		"typescript",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/application"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"bugs": "https://github.com/Marvin-Brouwer/rooted/issues",
	"sideEffects": false,
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"src/_module/tsconfig.project.json",
		"src/_module/tsconfig.project.plugin.json",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/application.mjs",
			"types": "./dist/application.d.mjs"
		},
		"./adapters": {
			"import": "./dist/adapters.mjs",
			"types": "./dist/adapters.d.mjs"
		},
		"./tsconfig": "./src/_module/tsconfig.project.json",
		"./tsconfig-plugin": "./src/_module/tsconfig.project.plugin.json"
	},
	"peerDependencies": {
		"@rooted/components": "workspace:^",
		"vite": ">= 8.0.1",
		"vite-bundle-analyzer": ">=  1.3.6",
		"vite-plugin-pwa": ">= 1.2.0"
	},
	"dependencies": {
		"@rooted/util": "workspace:^",
		"@vite-pwa/assets-generator": "^1.0.2",
		"happy-dom": "^20.9.0",
		"tinyglobby": "^0.2.16",
		"vite": "^8.0.12",
		"vite-bundle-analyzer": "^1.3.8",
		"vite-plugin-pwa": "^1.3.0"
	},
	"scripts": {
		"build": "pnpm build:ci",
		"build:dev": "pnpm build:ci && rooted-development extract-api",
		"build:ci": "tsdown",
		"watch": "tsdown --watch --no-clean",
		"clean": "rm -rf dist",
		"extract-api": "rooted-development extract-api"
	},
	"devDependencies": {
		"@rooted/components": "workspace:^",
		"@rooted/development": "workspace:*",
		"@rooted/router": "workspace:^",
		"@rooted/tsdown": "workspace:^",
		"@types/node": "^25.6.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
