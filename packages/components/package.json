{
	"name": "@rooted/components",
	"version": "0.1.0",
	"description": "rooted — web components rooted very close to the original",
	"keywords": [
		"web-components",
		"custom-elements",
		"framework-free",
		"typescript",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/components"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/components.mjs",
			"types": "./dist/components.d.mjs"
		},
		"./application": {
			"import": "./dist/application.mjs",
			"types": "./dist/application.d.mjs"
		},
		"./elements": {
			"import": "./dist/elements.mjs",
			"types": "./dist/elements.d.mjs"
		},
		"./css-loader": {
			"import": "./dist/css-loader.mjs",
			"types": "./dist/css-loader.d.mts"
		},
		"./css-loader/styles": {
			"types": "./plugin/styles.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@rooted/util": "workspace:^"
	},
	"peerDependencies": {
		"vite": ">=5.0.0"
	},
	"devDependencies": {
		"@rooted/tsup": "workspace:*",
		"@types/node": "^22.19.15",
		"esbuild": "^0.27.4",
		"vite": "^6.4.1"
	}
}