{
	"name": "@rooted/components",
	"version": "1.0.0-alpha.0",
	"description": "rooted — web components rooted very close to the original",
	"keywords": [
		"web-components",
		"custom-elements",
		"framework-free",
		"typescript",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/components"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"bugs": "https://github.com/Marvin-Brouwer/rooted/issues",
	"sideEffects": false,
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/components.mjs",
			"types": "./dist/components.d.mjs"
		},
		"./application": {
			"import": "./dist/application.mjs",
			"types": "./dist/application.d.mjs"
		},
		"./elements": {
			"import": "./dist/elements.mjs",
			"types": "./dist/elements.d.mjs"
		},
		"./events": {
			"import": "./dist/events.mjs",
			"types": "./dist/events.d.mjs"
		},
		"./css-loader": {
			"import": "./dist/css-loader.mjs",
			"types": "./dist/css-loader.d.mts"
		},
		"./css-loader/styles": {
			"types": "./plugins/styles.d.ts"
		}
	},
	"scripts": {
		"build": "pnpm build:ci",
		"build:dev": "pnpm build:ci && rooted-development extract-api",
		"build:ci": "tsup",
		"watch": "tsup --watch --no-clean & rooted-development extract-api",
		"clean": "rm -rf dist",
		"extract-api": "rooted-development extract-api"
	},
	"dependencies": {
		"@rooted/util": "workspace:^",
		"@rooted/elements": "workspace:^"
	},
	"peerDependencies": {
		"vite": ">=8.0.1"
	},
	"devDependencies": {
		"@rooted/development": "workspace:*",
		"@rooted/tsup": "workspace:^",
		"@types/node": "^25.5.2",
		"tsx": "^4.19.0",
		"esbuild": "^0.28.0",
		"vite": "^8.0.5"
	}
}
