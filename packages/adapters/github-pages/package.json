{
	"name": "@rooted-adapters/github-pages",
	"version": "1.0.0-alpha.0",
	"description": "Adapter for GitHub Pages",
	"keywords": [
		"web-components",
		"typescript",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/adapters/github-pages"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"bugs": "https://github.com/Marvin-Brouwer/rooted/issues",
	"sideEffects": false,
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		}
	},
	"peerDependencies": {
		"@rooted/adapter": "workspace:^",
		"vite": ">= 8.0.1"
	},
	"devDependencies": {
		"@rooted/adapter": "workspace:^",
		"@rooted/development": "workspace:*",
		"@rooted/tsdown": "workspace:^",
		"@types/node": "^25.9.3",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	},
	"scripts": {
		"build": "pnpm build:ci",
		"build:dev": "pnpm build:ci",
		"build:ci": "tsdown",
		"watch": "tsdown --watch --no-clean",
		"clean": "rm -rf dist"
	}
}
