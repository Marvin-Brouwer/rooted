{
	"name": "@rooted/events",
	"version": "1.0.0-alpha.0",
	"description": "rooted — event utilities",
	"keywords": [
		"web-components",
		"events",
		"framework-free",
		"typescript",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/events"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"bugs": "https://github.com/Marvin-Brouwer/rooted/issues",
	"sideEffects": false,
	"publishConfig": {
    	"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/events.mjs",
			"types": "./dist/events.d.mjs"
		}
	},
	"scripts": {
		"build": "pnpm build:ci",
		"build:dev": "pnpm build:ci && rooted-development extract-api",
		"build:ci": "tsup",
		"watch": "tsup --watch --no-clean & rooted-development extract-api",
		"clean": "rm -rf dist",
		"extract-api": "rooted-development extract-api"
	},
	"dependencies": {
		"@rooted/util": "workspace:^"
	},
	"devDependencies": {
		"@rooted/development": "workspace:*",
		"tsx": "^4.19.0"
	}
}