{
	"name": "@rooted/util",
	"version": "1.0.0-alpha.1",
	"description": "rooted — utilities (seeded IDs, dev helpers)",
	"keywords": [
		"web-components",
		"utilities",
		"typescript",
		"rooted"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Marvin-Brouwer/rooted.git",
		"directory": "packages/util"
	},
	"homepage": "https://github.com/Marvin-Brouwer/rooted#readme",
	"bugs": "https://github.com/Marvin-Brouwer/rooted/issues",
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"readme.md"
	],
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"import": "./dist/util.mjs",
			"types": "./dist/util.d.mjs"
		},
		"./dev": {
			"import": "./dist/dev.mjs",
			"types": "./dist/dev.d.mjs"
		}
	},
	"scripts": {
		"build": "pnpm build:ci",
		"build:dev": "pnpm build:ci && rooted-development extract-api",
		"build:ci": "tsup",
		"watch": "tsup --watch --no-clean & rooted-development extract-api",
		"clean": "rm -rf dist",
		"extract-api": "rooted-development extract-api"
	},
	"devDependencies": {
		"@rooted/development": "workspace:*",
		"tsx": "^4.19.0"
	}
}